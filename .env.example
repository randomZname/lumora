# .env.example — MVP_AI
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets. These are PLACEHOLDERS only.

# ---------------------------------------------------------------------------
# Database (Postgres) — reuse existing `bogi_db` container, separate `mvp_ai` db
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://bogi:CHANGEME@localhost:5432/mvp_ai

# ---------------------------------------------------------------------------
# Auth (NextAuth + Google)
# ---------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGEME_random_base64_secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---------------------------------------------------------------------------
# n8n orchestration / async video callback
# ---------------------------------------------------------------------------
# Webhook the app calls to kick off the pipeline (n8n production webhook URL).
N8N_WEBHOOK_URL=http://localhost:5678/webhook/video
# Shared secret n8n sends back on /api/video/callback (verified server-side).
N8N_CALLBACK_SECRET=CHANGEME_shared_callback_secret

# ---------------------------------------------------------------------------
# Video provider
# ---------------------------------------------------------------------------
# stub = wire the flow free with a sample clip; fal = real fal.ai generation.
VIDEO_PROVIDER=stub
FAL_KEY=your-fal-ai-api-key
# fal model endpoint. Cheap test default; swap to premium later, e.g.
#   fal-ai/kling-video/v2.5-turbo/pro/image-to-video
# Image-to-video model (default = Kling 2.5 Turbo Pro). Cheap alt: fal-ai/ltx-video-13b-distilled/image-to-video
FAL_MODEL=fal-ai/kling-video/v2.5-turbo/pro/image-to-video
# Text-to-video model (used when no image is uploaded).
FAL_MODEL_T2V=fal-ai/ltx-video-13b-distilled
# Public sample mp4 returned by the StubProvider callback.
SAMPLE_VIDEO_URL=https://test-videos.co.uk/vids/bigbuckbunny/mp4/h264/360/Big_Buck_Bunny_360_10s_1MB.mp4

# ---------------------------------------------------------------------------
# Storage (S3-compatible — MinIO dev / Cloudflare R2 prod)
# ---------------------------------------------------------------------------
# s3 = use S3-compatible endpoint (MinIO); local = LocalDiskStorage fallback.
STORAGE_DRIVER=s3
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=mvp-ai
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# MinIO root credentials (used by docker-compose for the minio service).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------------------------------------------------------------------------
# n8n container settings (used by docker-compose)
# ---------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Stripe (phase 4 — not used yet)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_CHANGEME
# STRIPE_WEBHOOK_SECRET=whsec_CHANGEME
# STRIPE_PRICE_PRO=price_CHANGEME
# STRIPE_PRICE_PREMIUM=price_CHANGEME
